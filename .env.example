# Operation Echo Shield — environment configuration.
# Copy to `.env` (docker compose reads `.env` automatically). All values have
# safe defaults baked into docker-compose.yml, so copying is optional.

# --- Protocol ---
A2A_VERSION=1.0
A2A_DEMO_TOKEN=resistance-demo-token

# --- Shared SQLite database (mounted volume path inside the Python containers) ---
A2A_DB_PATH=/data/mission.db

# --- Service URLs (docker network service names) ---
REGISTRY_URL=http://agent-registry:8000
COMMAND_AGENT_URL=http://command-agent:8001
INTELLIGENCE_AGENT_URL=http://intelligence-agent:8011
RELAY_AGENT_URL=http://communications-relay-agent:8012
TACTICAL_AGENT_URL=http://tactical-agent:8021
LOGISTICS_AGENT_URL=http://logistics-agent:8022
FLEET_AGENT_URL=http://fleet-agent:8023

# --- Registry discovery list: name|language|baseUrl, comma-separated ---
AGENT_ENDPOINTS=intelligence-agent|typescript|http://intelligence-agent:8011,communications-relay-agent|typescript|http://communications-relay-agent:8012,tactical-agent|go|http://tactical-agent:8021,logistics-agent|go|http://logistics-agent:8022,fleet-agent|go|http://fleet-agent:8023,resistance-command-agent|python|http://command-agent:8001

# --- Mission auto-start (Command Agent) ---
AUTOSTART_MISSION=true
MISSION_START_DELAY_SECONDS=6

# --- Resilience toggle (working): when true, the Command Agent injects one
#     transient failure that recovers on retry attempt 2 (logged to audit_logs)
#     and one doomed call that exhausts all retries and lands in the dead_letters
#     table (surfaced as a status="dead-letter" transmission) BEFORE the real
#     mission, which then proceeds normally. Leave false (default) for a clean
#     10/10 run. The `make demo-resilience` target flips this on for one run and
#     restores the default afterward. ---
FAILURE_SIMULATION=false

# --- Published host ports. Defaults match the documented ports; override any of
#     these if a port is already in use on your host (the in-container ports and
#     all inter-agent URLs are unchanged, so only your browser/curl target moves).
#     Example: COMMAND_HOST_PORT=18001 if something else already owns 8001. ---
REGISTRY_HOST_PORT=8000
COMMAND_HOST_PORT=8001
DASHBOARD_HOST_PORT=8080
INTEL_HOST_PORT=8011
RELAY_HOST_PORT=8012
TACTICAL_HOST_PORT=8021
LOGISTICS_HOST_PORT=8022
FLEET_HOST_PORT=8023
